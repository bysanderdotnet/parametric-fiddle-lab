# --- AI harness (template-ai-harness) ---
# Files the harness writes locally at runtime; never commit them.
# Per-user agent settings (Claude Code):
.claude/settings.local.json
# Transient scratch state, written by ./AGENTS.sh verify:
.agents/agents.scratch.json
# Python bytecode cache from running the harness CLI:
.agents/__pycache__/

